<html>
<head>
<meta http-equiv="x-ua-compatible" content="ie=edge">
<meta charset="utf-8">
<title>DYE MASTER Launcher</title>
<HTA:APPLICATION
  ID="DyeMasterLauncher"
  APPLICATIONNAME="DYE MASTER Launcher"
  BORDER="thin"
  BORDERSTYLE="normal"
  INNERBORDER="no"
  SCROLL="no"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="normal"
/>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'Segoe UI',sans-serif; background:#0f172a; color:#f8fafc; height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; user-select:none; }
h1 { font-size:2rem; font-weight:900; letter-spacing:4px; margin-bottom:0.3rem; background:linear-gradient(135deg,#667eea,#764ba2); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
.sub { color:#64748b; font-size:0.8rem; margin-bottom:2rem; letter-spacing:1px; }
.cards { display:flex; gap:1.2rem; margin-bottom:1.5rem; }
.card { width:220px; padding:1.5rem; background:rgba(30,41,59,0.8); border:1px solid rgba(255,255,255,0.08); border-radius:16px; text-align:center; cursor:pointer; transition:all 0.2s; }
.card:hover { border-color:rgba(139,92,246,0.5); transform:translateY(-3px); box-shadow:0 8px 30px rgba(139,92,246,0.15); }
.card-icon { font-size:2.2rem; margin-bottom:0.6rem; }
.card-title { font-size:1rem; font-weight:700; margin-bottom:0.3rem; }
.card-desc { font-size:0.75rem; color:#94a3b8; line-height:1.5; }
.card-port { display:inline-block; margin-top:0.6rem; padding:0.2rem 0.7rem; background:rgba(139,92,246,0.15); border-radius:20px; font-size:0.7rem; color:#a78bfa; letter-spacing:1px; }
.status { font-size:0.75rem; color:#64748b; margin-top:0.5rem; min-height:2.5rem; text-align:center; max-width:500px; line-height:1.6; }
.status.ok { color:#34d399; }
.status.err { color:#f87171; }
.link { color:#818cf8; cursor:pointer; text-decoration:underline; }
.bottom { position:absolute; bottom:1rem; font-size:0.65rem; color:#334155; }
</style>
<script>
// 창 크기를 760x460으로 축소하고 중앙 정렬
window.resizeTo(760, 460);
window.moveTo((screen.width - 760) / 2, (screen.height - 460) / 2);

var shell = new ActiveXObject("WScript.Shell");
var fso = new ActiveXObject("Scripting.FileSystemObject");
var scriptDir = (function() {
  var path = document.location.pathname.replace(/^\//, '').replace(/\//g, '\\');
  return fso.GetParentFolderName(unescape(path));
})();

function setStatus(msg, type) {
  var el = document.getElementById('status');
  el.innerHTML = msg;
  el.className = 'status ' + (type || '');
}

function startServer(mode) {
  var cwd, port, label;
  if (mode === 'dist') {
    cwd = scriptDir + '\\dist';
    port = '9090';
    label = '배포(dist)';
  } else {
    cwd = scriptDir;
    port = '8080';
    label = '개발(dev)';
  }

  if (!fso.FolderExists(cwd)) {
    if (mode === 'dist') {
      setStatus('⚠ dist/ 폴더가 없습니다. 먼저 빌드를 실행하세요.<br>CMD: <b>node tools/build.js</b>', 'err');
    } else {
      setStatus('⚠ 폴더를 찾을 수 없습니다: ' + cwd, 'err');
    }
    return;
  }

  var cmd = 'cmd /c "cd /d ' + cwd + ' && set PORT=' + port + ' && node server/index.js"';
  try {
    shell.Run(cmd, 1, false);
    setStatus('✅ ' + label + ' 서버 시작됨!<br><span class="link" onclick="openBrowser(\'http://localhost:' + port + '\')">http://localhost:' + port + '</span>  |  <span class="link" onclick="openBrowser(\'http://10.28.42.23:' + port + '\')">http://10.28.42.23:' + port + '</span>', 'ok');
  } catch(e) {
    setStatus('❌ 서버 시작 실패: ' + e.message, 'err');
  }
}

function buildDist() {
  var cmd = 'cmd /k "cd /d ' + scriptDir + ' && node tools/build.js"';
  try {
    shell.Run(cmd, 1, false);
    setStatus('📦 빌드 실행 중... CMD 창을 확인하세요.', 'ok');
  } catch(e) {
    setStatus('❌ 빌드 실패: ' + e.message, 'err');
  }
}

function openBrowser(url) {
  shell.Run('cmd /c start ' + url, 0, false);
}
</script>
</head>
<body>
<h1>DYE MASTER</h1>
<div class="sub">SERVER LAUNCHER</div>
<div class="cards">
  <div class="card" onclick="startServer('dev')">
    <div class="card-icon">🛠</div>
    <div class="card-title">개발 서버</div>
    <div class="card-desc">소스 폴더에서 직접 실행<br>DEV START 버튼 포함</div>
    <div class="card-port">:8080</div>
  </div>
  <div class="card" onclick="startServer('dist')">
    <div class="card-icon">🚀</div>
    <div class="card-title">배포 서버</div>
    <div class="card-desc">dist/ 빌드 버전 실행<br>DEV 버튼 제거됨</div>
    <div class="card-port">:9090</div>
  </div>
  <div class="card" onclick="buildDist()">
    <div class="card-icon">📦</div>
    <div class="card-title">빌드</div>
    <div class="card-desc">배포 ZIP 재생성<br>dist/ 폴더 갱신</div>
    <div class="card-port">build.js</div>
  </div>
</div>
<div id="status" class="status">카드를 클릭하여 서버를 시작하세요</div>
<div class="bottom">DYE MASTER v3.0 — 더블클릭으로 이 런처를 실행하세요</div>
</body>
</html>
