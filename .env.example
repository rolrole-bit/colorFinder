# DYE MASTER 환경 변수
# 이 파일을 .env로 복사하여 사용하세요

# 서버 포트
PORT=8080

# 노드 환경 (development | production)
NODE_ENV=production

# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Rate Limit 설정
RATE_LIMIT_SESSION=5
RATE_LIMIT_ROUND=20
RATE_LIMIT_RANKING=30

# 세션/랭킹 상한
MAX_SESSIONS=1000
MAX_RANKINGS=1000

# HTTPS (리버스 프록시 뒤에서 운용 시)
TRUST_PROXY=false
