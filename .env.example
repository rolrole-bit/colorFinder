# DYE MASTER 환경 변수
# 이 파일을 .env로 복사하여 사용하세요

# 서버 포트
PORT=8080

# 노드 환경 (development | production)
NODE_ENV=production

# ═══════════════════════════════════════════
# CORS 허용 오리진 (접속 가능한 주소)
# ═══════════════════════════════════════════

# 로컬 전용 (기본)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# 온라인 배포: 전체 허용 (간편)
# CORS_ORIGINS=*

# 온라인 배포: 도메인 지정 (보안 권장)
# CORS_ORIGINS=https://game.example.com,https://www.game.example.com

# LAN 접속 허용 (내부 IP 추가)
# CORS_ORIGINS=http://localhost:8080,http://192.168.1.100:8080

# ═══════════════════════════════════════════
# Rate Limit 설정
# ═══════════════════════════════════════════
RATE_LIMIT_SESSION=5
RATE_LIMIT_ROUND=20
RATE_LIMIT_RANKING=30

# ═══════════════════════════════════════════
# 세션/랭킹 상한
# ═══════════════════════════════════════════
MAX_SESSIONS=1000
MAX_RANKINGS=1000

# ═══════════════════════════════════════════
# 리버스 프록시 (Nginx, Cloudflare 등)
# ═══════════════════════════════════════════
# 온라인 배포 시 true로 설정 (Rate Limit IP 정확도)
TRUST_PROXY=false
